# Production Environment Variables Template
# Copy these to your hosting platform's environment variables section

# SECURITY - Generate new values using: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secure-production-secret-key-here
JWT_SECRET_KEY=your-secure-production-jwt-secret-key-here

# DATABASE - Use your hosting platform's PostgreSQL connection string
DATABASE_URL=postgresql://username:password@host:5432/database_name

# RESEND EMAIL API
RESEND_API_KEY=your_resend_api_key_here
OWNER_EMAIL=your-business-email@example.com

# FRONTEND & BACKEND URLS (IMPORTANT!)
CLIENT_ORIGIN=https://your-frontend-domain.vercel.app
APP_URL=https://your-backend-domain.onrender.com
PORT=5000

# M-PESA PRODUCTION (Get from Safaricom Daraja Portal)
MPESA_ENV=production
MPESA_BASE_URL=https://api.safaricom.co.ke
MPESA_CONSUMER_KEY=your_production_consumer_key
MPESA_CONSUMER_SECRET=your_production_consumer_secret
MPESA_SHORTCODE=your_production_shortcode
MPESA_PASSKEY=your_production_passkey
MPESA_CALLBACK_URL=https://your-backend-domain.onrender.com/api/payment/mpesa/callback

# EMAIL (Gmail or your SMTP provider)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# FILE UPLOADS
UPLOAD_FOLDER=uploads
