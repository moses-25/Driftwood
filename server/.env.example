# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to git!

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/database_name
SECRET_KEY=your-secret-key-here-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-here-change-in-production

# Your Resend API key — get it from https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key_here

# The email address that receives contact form submissions (the café owner)
OWNER_EMAIL=your-email@example.com

# The origin of your frontend (used for CORS)
CLIENT_ORIGIN=http://localhost:5176

# Port the server listens on (optional, defaults to 5000)
PORT=5000

# Application URL (for M-Pesa callbacks)
APP_URL=http://localhost:5000

# M-Pesa Configuration (for production)
# Get these from Safaricom Daraja Portal: https://developer.safaricom.co.ke/
MPESA_CONSUMER_KEY=your_mpesa_consumer_key_here
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret_here
MPESA_SHORTCODE=your_shortcode_here
MPESA_PASSKEY=your_passkey_here

# Email Configuration
# For Gmail, use App Password: https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password-here

# File Upload
UPLOAD_FOLDER=uploads
